# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_COMMAND_TOPIC=sms-commands
KAFKA_BATCH_STARTED_TOPIC=sms-batch-started
KAFKA_BATCH_READY_TOPIC=sms-batch-ready
KAFKA_DELIVERY_RESULTS_TOPIC=sms-delivery-results
KAFKA_RETRY_QUEUE_TOPIC=sms-retry-queue
KAFKA_DLQ_TOPIC=sms-dlq

# PostgreSQL Configuration (for Layer 2)
POSTGRES_HOST=campaign-db
POSTGRES_PORT=5432
POSTGRES_DB=campaign_db
POSTGRES_USER=campaign_user
POSTGRES_PASSWORD=campaign_pass

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# SMSC Provider Configuration (for Layer 4)
SMSC_API_URL=https://api.twilio.com/2010-04-01/Accounts/ACXXXXXXXXXXXXXXXXXX/Messages.json
SMSC_API_KEY=your_account_sid
SMSC_API_SECRET=your_auth_token
SMSC_SENDER=+1234567890

# Performance Tuning
GLOBAL_TPS_LIMIT=1000
BATCH_SIZE=1000
THROTTLE_BATCH_SIZE=100
PULL_INTERVAL_MS=100
MAX_RETRIES=3
RETRY_BACKOFF=1,5,30
CONCURRENT_WORKERS=10